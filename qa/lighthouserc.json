{
  "ci": {
    "collect": {
      "startServerCommand": "npm run dev -- -p 3456",
      "url": [
        "http://localhost:3456",
        "http://localhost:3456/us",
        "http://localhost:3456/uk",
        "http://localhost:3456/us/salary/software-engineer",
        "http://localhost:3456/us/tools/tax-calculator",
        "http://localhost:3456/about",
        "http://localhost:3456/rankings",
        "http://localhost:3456/compare"
      ],
      "numberOfRuns": 1
    },
    "assert": {
      "preset": "lighthouse:no-pwa",
      "assertions": {
        "categories:accessibility": ["warn", { "minScore": 0.8 }],
        "categories:performance": ["warn", { "minScore": 0.6 }],
        "categories:seo": ["error", { "minScore": 0.9 }],
        "cumulative-layout-shift": ["warn", { "minScore": 0.8 }]
      }
    },
    "upload": {
      "target": "filesystem",
      "outputDir": "./qa/lighthouse-reports"
    }
  }
}
